@model IEnumerable<Actor>
<link rel="stylesheet" href="~/css/site-ui.css" />

@{
    ViewData["Title"] = "Actors List";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">

            @await Html.PartialAsync("_CreateItem", "Actors")

            <table class="table table-hover text-center align-middle shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Profile Picture</th>
                        <th>Full Name</th>
                        <th>Biography</th>
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <!-- الصورة -->
                            <td>
                                <div class="cinema-img-container cinema-img-sm">
                                    <img src="@item.ProfilePictureURL"
                                         class="cinema-img"
                                         alt="@item.FullName" />
                                </div>
                            </td>

                            <!-- الاسم -->
                            <td class="fw-bold">
                                @item.FullName
                            </td>

                            <!-- البايو -->
                            <td class="text-muted">
                                @(item.Bio.Length > 60
                                    ? item.Bio.Substring(0, 60) + "..."
                                    : item.Bio)
                            </td>

                            <!-- الأكشن -->
                            @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                            {
                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        <a class="btn btn-outline-primary btn-sm"
                                               asp-action="Edit" asp-route-id="@item.Id">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <a class="btn btn-outline-info btn-sm"
                                               asp-action="Details" asp-route-id="@item.Id">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a class="btn btn-outline-danger btn-sm"
                                               asp-action="Delete" asp-route-id="@item.Id">
                                            <i class="bi bi-trash"></i>
                                        </a>

                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>