@model Actor
@{
    ViewData["Title"] = Model.FullName;
}

<link rel="stylesheet" href="~/css/actor-img.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <h2 id="ActorTitle" class="text-center fw-bold mb-4">
                     @Model.FullName
                </h2>

                <form asp-action="Edit">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Image Preview -->
                    <div class="text-center mb-4">
                        <img id="ProfilePicturePreview"
                             class="rounded-circle"
                             style="width:180px; height:180px; object-fit:cover; border:4px solid #0dcaf0;" />
                    </div>

                    <!-- Profile URL -->
                    <div class="mb-3">
                        <label asp-for="ProfilePictureURL" class="form-label fw-semibold"></label>
                        <input asp-for="ProfilePictureURL" class="form-control form-control-lg" placeholder="Paste image URL (e.g. https://image.jpg)" />
                        <span asp-validation-for="ProfilePictureURL" class="text-danger"></span>
                    </div>

                    <!-- Name -->
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" id="FullNameInput" class="form-control form-control-lg" placeholder="e.g. Leonardo DiCaprio" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <!-- Bio -->
                    <div class="mb-4">
                        <label asp-for="Bio" class="form-label fw-semibold"></label>
                        <textarea asp-for="Bio"
                                  id="BioInput"
                                  class="form-control"
                                  rows="4"
                                  maxlength="200"
                                  placeholder="Write a short biography (e.g. Academy Award-winning actor known for roles in Inception and Titanic...)"
                                  style="line-height:1.6;"></textarea>
                        <span asp-validation-for="Bio" class="text-danger"></span>
                        <small id="bioCounter" class="text-muted">0 characters</small>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex justify-content-between align-items-center">

                        <a class="btn btn-outline-secondary px-4"
                               asp-action="Index">
                            ← Back 
                        </a>

                        <button type="submit" class="btn btn-outline-success px-4">
                            <i class="bi bi-check-circle"></i> Update
                        </button>

                    </div>

                </form>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // Image Preview
            function updateImagePreview(url) {
                var output = document.getElementById('ProfilePicturePreview');

                if (url && url.trim() !== "") {
                    output.src = url;
                } else {
                    output.src = "";
                }
            }

            updateImagePreview($("#ProfilePictureURL").val());

            $("#ProfilePictureURL").on("input", function () {
                updateImagePreview($(this).val());
            });

            // Dynamic Placeholder
            function updatePlaceholder() {
                var name = $("#FullNameInput").val().trim();

                if (name.length > 0) {
                    $("#BioInput").attr(
                        "placeholder",
                        "Write a short biography about " + name + "..."
                    );
                } else {
                    $("#BioInput").attr(
                        "placeholder",
                        "Write a short biography (e.g. Academy Award-winning actor...)"
                    );
                }
            }

            $("#FullNameInput").on("input", function () {
                updatePlaceholder();
            });

            updatePlaceholder();

            // 🔤 Dynamic Title
            $("#FullNameInput").on("input", function () {
                let name = $(this).val().trim();
                $("#ActorTitle").text(name !== "" ? name : "Edit Actor");
            });

            // 🔢 Bio Counter
            function updateCounter() {
                let length = $("#BioInput").val().length;
                $("#bioCounter").text(length + " characters");

                if (length > 150) {
                    $("#bioCounter").addClass("text-danger");
                } else {
                    $("#bioCounter").removeClass("text-danger");
                }
            }

            // تشغيل أول مرة
            updateCounter();

            // عند الكتابة
            $("#BioInput").on("input", function () {
                updateCounter();
            });

        });
    </script>
}