@model Actor
@{
    ViewData["Title"] = "Delete Actor";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-4 p-4 text-center">

                <!-- Title -->
                <h2 class="text-danger fw-bold mb-3">
                    ⚠️ Delete Actor
                </h2>

                <p class="text-muted mb-4">
                    Are you sure you want to delete this actor? This action cannot be undone.
                </p>

                <!-- Image -->
                <img src="@Model.ProfilePictureURL"
                     class="rounded-circle mx-auto mb-3"
                     style="width:150px; height:150px; object-fit:cover; border:4px solid #dc3545;" />

                <!-- Name -->
                <h4 class="fw-bold">@Model.FullName</h4>

                <!-- Bio -->
                <p class="text-muted px-3 mt-2" style="line-height:1.6;">
                    @Model.Bio
                </p>

                <hr />

                <!-- Buttons -->
                <div class="d-flex justify-content-center gap-3 mt-3">

                    <a class="btn btn-outline-secondary px-4"
                           asp-action="Index">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>

                    <form asp-action="Delete" method="post"
                          onsubmit="return confirm('Are you sure you want to delete this actor?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </form>

                </div>

            </div>

        </div>
    </div>
</div>