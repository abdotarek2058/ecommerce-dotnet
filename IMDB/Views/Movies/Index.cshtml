@model PaginatedResult<Movie>
<link rel="stylesheet" href="~/css/movie-img.css">
@{
    ViewData["Title"] = "Movies List";
}
<div class="row">
    <div id="skeleton-container" class="row">
        @for (int i = 0; i < 6; i++)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="skeleton skeleton-image"></div>
                    <div class="card-body">
                        <div class="skeleton skeleton-text"></div>
                        <div class="skeleton skeleton-text"></div>
                        <div class="skeleton skeleton-text"></div>

                    </div>
                </div>
            </div>
        }
    </div>
    <div id="movies-container" class="row g-4" style="display:none;">
            @foreach (var item in Model.Data)
            {
                <div class="col-lg-4 col-md-6 movie-card">
                    <div class="card h-100">
                        <div class="row g-0">
                            <div class="col-md-12">
                                <div class="card-header text-white bg-info">
                                    <p class="card-text">
                                        <h5 class="card-title">
                                            @item.Name
                                            @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                                            {
                                                <a class="text-white float-end" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil-square"></i></a>
                                            }
                                        </h5>
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-6 movie-poster p-0">
                                <img src="@item.ImageURL" class="movie-img" alt="@item.Name" />
                            </div>
                        
                            <div class="col-md-6 p-0">
                                <div class="card-body d-flex flex-column h-100">
                                    <p class="card-text">@(item.Description.Length > 120 ? item.Description.Substring(0,120) +  "..." : item.Description)</p>
                                    <p class="card-text"><b>Cinema: </b>@item.Cinema.Name</p>
                                    <p class="card-text"><b>Category: </b>@item.MovieCategory</p>
                                    <p class="card-text"><b>Start Date: </b>@item.StartDate.ToString("dd MMM yy",new System.Globalization.CultureInfo("ar-EG"))</p>
                                    <p class="card-text"><b>End Date : </b>@item.EndDate.ToString("dd MMM yy",new System.Globalization.CultureInfo("ar-EG"))</p>
                                    <p class="card-text">
                                        <b>Status: </b>
                                        @if (DateTime.Now >= item.StartDate && DateTime.Now <= item.EndDate)
                                        {
                                            <span class="badge bg-success text-white">AVAILABLE</span>
                                        }
                                        else if (DateTime.Now > item.EndDate)
                                        {
                                            <span class="badge bg-danger text-white">EXPIRED</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary text-white">UPCOMING</span>
                                        }
                                    </p>
                                    <p class="text-end movie-rating mt-auto rating-@((int)item.Rating)" style="font-size:18px;">

                                        @{
                                            var rating = item.Rating / 2.0;
                                            var fullStars = Math.Floor(rating);
                                            var hasHalfStar = rating - fullStars >= 0.5;
                                        }

                                        @for (int i = 1; i <= fullStars; i++)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }

                                        @if (hasHalfStar)
                                        {
                                            <i class="bi bi-star-half"></i>
                                        }

                                        @for (int i = (int)(fullStars + (hasHalfStar ? 1 : 0)) + 1; i <= 5; i++)
                                        {
                                            <i class="bi bi-star"></i>
                                        }

                                        <span class="rating-number ms-1">(@item.Rating)</span>


                                    </p>

                                </div>
                            </div>
                        
                            <div class="col-md-12">
                                <div class="card-footer">
                                    <div class="card-text d-flex  align-items-center gap-4">
                                        <a class="btn btn-outline-primary"
                                           asp-action="Details"
                                           asp-route-id="@item.Id">
                                           <i class="bi bi-eye-fill"></i> Show Details
                                       </a>
                                        <form asp-controller="Orders"
                                              asp-action="AddItemToShoppingCart"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              style="margin:0;">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-success text-white"
                                                    @(DateTime.Now > item.EndDate ? "disabled" : "")>
                                                <i class="bi bi-cart-plus"></i>
                                                Add to Cart (Price @item.Price.ToString("c"))
                                            </button>

                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
    
    </div>

</div>
    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success add-btn-floating">
            <i class="bi bi-plus-lg"></i>
        </a>
    }
    <div id="movies-pagination" class="d-flex justify-content-center mt-4">

        @if (Model.PageNumber > 1)
        {
            <a class="btn btn-outline-primary me-2"
                   asp-action="Index"
                   asp-route-page="@(Model.PageNumber - 1)"
                   asp-route-search="@ViewBag.Search">
                &laquo;
            </a>
        }

        <span class="align-self-center">
            Page @Model.PageNumber of @Model.TotalPages
        </span>

        @if (Model.PageNumber < Model.TotalPages)
        {
            <a class="btn btn-outline-primary ms-2"
                   asp-action="Index"
                   asp-route-page="@(Model.PageNumber + 1)"
                   asp-route-search="@ViewBag.Search">
                &raquo;
            </a>
        }

    </div>
