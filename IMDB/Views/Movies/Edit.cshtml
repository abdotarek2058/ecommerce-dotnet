@model NewMovie
@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <!-- Title -->
                <h2 class="text-center fw-bold mb-4">
                    🎬 Update Movie
                </h2>

                <form asp-action="Edit">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">

                        <!-- LEFT SIDE -->
                        <div class="col-md-6">

                            <!-- Image Preview -->
                            <div class="text-center mb-4">
                                <img id="ImageUrlPreview"
                                     class="rounded-4 shadow"
                                     style="width:220px; height:300px; object-fit:cover;" />
                            </div>

                            <!-- Name -->
                            <div class="mb-3">
                                <label asp-for="Name" class="form-label fw-semibold"></label>
                                <input asp-for="Name" class="form-control form-control-lg" />
                            </div>

                            <!-- Dates -->
                            <div class="row">
                                <div class="col">
                                    <label asp-for="StartDate" class="form-label fw-semibold"></label>
                                    <input asp-for="StartDate" type="date" class="form-control" />
                                </div>

                                <div class="col">
                                    <label asp-for="EndDate" class="form-label fw-semibold"></label>
                                    <input asp-for="EndDate" type="date" class="form-control" />
                                </div>
                            </div>

                            <!-- Price -->
                            <div class="mt-3">
                                <label asp-for="Price" class="form-label fw-semibold"></label>
                                <input asp-for="Price" type="number" step="0.01" min="0" lang="en" class="form-control" />
                            </div>

                            <!-- Rating -->
                            <div class="mt-3">
                                <label asp-for="Rating" class="form-label fw-semibold"></label>
                                <input asp-for="Rating" id="ratingInput"
                                       type="number" step="0.1" min="0" max="10"
                                       class="form-control" />

                                <div id="starsPreview" class="mt-2 text-warning fs-4"></div>
                            </div>

                            <!-- Image URL -->
                            <div class="mt-3">
                                <label asp-for="ImageURL" class="form-label fw-semibold"></label>
                                <input asp-for="ImageURL" id="ImageURL" class="form-control" />
                            </div>

                        </div>

                        <!-- RIGHT SIDE -->
                        <div class="col-md-6">

                            <div class="mb-3">
                                <label asp-for="CinemaId" class="form-label fw-semibold"></label>
                                <select asp-for="CinemaId" class="form-select"
                                        asp-items="ViewBag.Cinemas"></select>
                            </div>

                            <div class="mb-3">
                                <label asp-for="MovieCategory" class="form-label fw-semibold"></label>
                                <select asp-for="MovieCategory" class="form-select"
                                        asp-items="Html.GetEnumSelectList<MovieCategory>()"></select>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ProducerId" class="form-label fw-semibold"></label>
                                <select asp-for="ProducerId" class="form-select"
                                        asp-items="ViewBag.Producers"></select>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ActorIds" class="form-label fw-semibold"></label>
                                <select asp-for="ActorIds" class="form-select"
                                        asp-items="ViewBag.Actors" multiple
                                        style="height:150px;"></select>
                            </div>

                            <!-- Description -->
                            <div class="mb-3">
                                <label asp-for="Description" class="form-label fw-semibold"></label>
                                <textarea asp-for="Description"
                                          class="form-control"
                                          rows="4"></textarea>
                            </div>

                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex justify-content-between mt-4">

                        <a class="btn btn-outline-secondary px-4"
                               asp-action="Index">
                            ← Show All Movies
                        </a>

                        <button type="submit" class="btn btn-outline-success px-4">
                            <i class="bi bi-check-circle"></i> Update
                        </button>

                    </div>

                </form>

            </div>

        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {

            // 🖼️ Image Preview
            function updateImagePreview(url) {
                let img = $("#ImageUrlPreview");

                if (url && url.trim() !== "") {
                    img.attr("src", url);
                } else {
                    img.attr("src", "");
                }
            }

            updateImagePreview($("#ImageURL").val());

            $("#ImageURL").on("input", function () {
                updateImagePreview($(this).val());
            });

            // ⭐ Rating Stars
            function updateStars() {
                let rating = parseFloat($("#ratingInput").val()) || 0;
                let stars = "";

                for (let i = 1; i <= 5; i++) {
                    if (rating >= i * 2)
                        stars += "★";
                    else
                        stars += "☆";
                }

                $("#starsPreview").text(stars + " (" + rating + ")");
            }

            updateStars();

            $("#ratingInput").on("input", function () {
                updateStars();
            });

        });
    </script>
}
