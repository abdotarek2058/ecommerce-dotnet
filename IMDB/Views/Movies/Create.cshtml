@model NewMovie
@{
    ViewData["Title"] = "Create Movie";
}
<link rel="stylesheet" href="/css/movie-img.css" />
<div class="container mt-5">
    <div class="create-card mx-auto">

        <h2 class="text-center mb-4 fw-bold">
            🎬 Create a New Movie
        </h2>

        <form asp-action="Create">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-4">

                <!-- LEFT -->
                <div class="col-md-6">

                    <div>
                        <label asp-for="Name"></label>
                        <input asp-for="Name" id="movieNameInput" class="form-control" placeholder="Movie Name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div>
                        <label asp-for="StartDate"></label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                    </div>

                    <div>
                        <label asp-for="EndDate"></label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                    </div>

                    <div>
                        <label asp-for="Price"></label>
                        <input asp-for="Price" type="number" step="0.01" min="0" lang="en" class="form-control" />
                    </div>

                    <div>
                        <label asp-for="Rating" class="form-label fw-semibold"></label>
                        <input asp-for="Rating" id="ratingInput"
                               type="number" step="0.1" min="0" max="10"
                               class="form-control" placeholder="Movie Rating" />

                        <!-- النجوم -->
                        <div id="starRating" class="star-rating mt-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi bi-star" data-value="@i"></i>
                            }
                            <span id="ratingValue">(0)</span>
                        </div>
                    </div>

                    <div id="starsPreview" class="text-warning fs-4 mt-2"></div>

                    <div>
                        <label asp-for="ImageURL"></label>

                        <div class="d-flex align-items-center justify-content-between">

                            <!-- LEFT: INPUT -->
                            <div class="drop-zone flex-grow-1 me-4" style="max-width: 400px; width: 100%;">
                                
                                <input asp-for="ImageURL" id="imageInput" class="form-control" placeholder="Movie Url" />
                            </div>

                            
                            

                        </div>
                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-md-6">
                   
                    <div>
                        <label asp-for="CinemaId"></label>
                        <select asp-for="CinemaId" class="form-select" asp-items="ViewBag.Cinemas"></select>
                    </div>

                    <div>
                        <label asp-for="MovieCategory"></label>
                        <select asp-for="MovieCategory" class="form-select"
                                asp-items="Html.GetEnumSelectList<MovieCategory>()"></select>
                    </div>

                    <div>
                        <label asp-for="ProducerId"></label>
                        <select asp-for="ProducerId" class="form-select" asp-items="ViewBag.Producers"></select>
                    </div>

                    <div>
                        <label asp-for="ActorIds"></label>
                        <select asp-for="ActorIds" class="form-select" asp-items="ViewBag.Actors" multiple></select>
                    </div>

                    <div class="text-center mb-3">
                        <img id="ImageUrlPreview" class="img-preview" />
                    </div>

                </div>

                <!-- DESCRIPTION -->
                <div class="col-12">
                    <label asp-for="Description"></label>
                    <textarea asp-for="Description" id="descriptionInput" class="form-control" rows="4" placeholder="Enter movie description..."></textarea>
                    <div class="text-end mt-1">
                        <small id="descCounter">0 / 500</small>
                    </div>
                </div>

                

            </div>

            <!-- BUTTONS -->
            <div class="d-flex justify-content-between mt-4">

                <a asp-action="Index" class="btn btn-outline-secondary">
                    ← Back
                </a>

                <button type="submit" class="btn btn-success create-btn" id="submitBtn">
                    <i class="bi bi-plus-circle"></i> Create Movie
                </button>

            </div>

        </form>

    </div>
</div>
@section Scripts {
<script>

    const input = document.getElementById("ratingInput");
    const ratingText = document.getElementById("ratingValue");
    const stars = document.querySelectorAll("#starRating i");

    function updateStars(value) {

        let full = Math.floor(value / 2);
        let half = value % 2 >= 1;

        stars.forEach((star, i) => {


            star.className = "bi";

            if (i < full) {
                star.classList.add("bi-star-fill", "active");
            } else if (i === full && half) {
                star.classList.add("bi-star-half", "active");
            } else {
                star.classList.add("bi-star");
            }
        });

        ratingText.innerText = `(${value})`;
    }

    updateStars(parseFloat(input.value) || 0); // 👈 هنا

    // لما تكتب في input
    input.addEventListener("input", () => {
        let value = parseFloat(input.value) || 0;
        updateStars(value);
    });

        // لما تضغط نجوم
    stars.forEach((star, index) => {

        star.addEventListener("click", () => {
            let value = (index + 1) * 2; // من 10
            input.value = value;
            updateStars(value);
        });

    });

    

   const dropZone = document.querySelector(".drop-zone");
   const inputImg = document.getElementById("imageInput");

   function showImage() {

       const img = document.getElementById("ImageUrlPreview");

       if (inputImg.value.trim() !== "") {
           img.src = inputImg.value;
           img.style.display = "block";
           img.classList.add("show");
       } else {
           img.style.display = "none";
           img.classList.remove("show");
       }
   }
   // 👇 أهم سطرين
   inputImg.addEventListener("keyup", showImage);
   inputImg.addEventListener("change", showImage);
   // 👇 عشان تظهر لو فيه value جاهزة
   showImage();

   dropZone.addEventListener("click", () => inputImg.click());

   dropZone.addEventListener("dragover", e => {
       e.preventDefault();
       dropZone.classList.add("dragover");
   });

   dropZone.addEventListener("dragleave", () => {
       dropZone.classList.remove("dragover");
   });

   dropZone.addEventListener("drop", e => {

       e.preventDefault();
       dropZone.classList.remove("dragover");

       const file = e.dataTransfer.files[0];
       const reader = new FileReader();

       reader.onload = function (event) {
           const img = document.getElementById("ImageUrlPreview");
           img.src = event.target.result;
           img.style.display = "block";
           img.classList.add("show");
       };
            reader.readAsDataURL(file);
   });

    document.querySelector("form").addEventListener("submit", function () {

        const btn = document.getElementById("submitBtn");

        btn.innerHTML = "Creating...";
        btn.disabled = true;

        btn.style.transform = "scale(0.95)";
    });

    const descInput = document.getElementById("descriptionInput");
    const counter = document.getElementById("descCounter");

    const maxLength = 500;

       
    function updateCounter() {

         const length = descInput.value.length;
         counter.innerText = `${length} / ${maxLength}`;

           
         if (length > maxLength - 50) {

             counter.style.color = "red";
         } else {

             counter.style.color = "#6c757d";
         }
    }

      
    updateCounter();

      
    descInput.addEventListener("input", updateCounter);

    const movieNameInput = document.getElementById("movieNameInput");

            movieNameInput.addEventListener("input", () => {

            const movieName = movieNameInput.value.trim();

            if (movieName !== "") {
                descInput.placeholder = `Enter movie description for ${movieName}`;
            } else {
                descInput.placeholder = "Enter movie description...";
            }

        });
</script>
    
}
