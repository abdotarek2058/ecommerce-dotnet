@model Movie
@{
    ViewData["Title"] = "Movie Details";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}
<link rel="stylesheet" href="~/css/actor-img.css" />
<link rel="stylesheet" href="~/css/movie-img.css">
<div class="row">
    <div class="col-md-8 offset-2">
        <div class="card mb-12">
            <div class="row g-0">
                <div class="col-md-12">
                    <div class="card-header text-white bg-info">
                        <p class="card-text">
                                <h5 class="card-title d-flex justify-content-between align-items-center">

                                    <span>@Model.Name</span>

                                    <span class="movie-rating rating-@((int)Model.Rating)" style="font-size:18px;">

                                        @{
                                            var rating = Model.Rating / 2.0;
                                        }

                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= Math.Floor(rating))
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }
                                            else if (i - rating < 1)
                                            {
                                                <i class="bi bi-star-half"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star"></i>
                                            }
                                        }

                                        <span class="ms-1">(@Model.Rating)</span>

                                    </span>

                                </h5>
                        </p>
                    </div>
                </div>
                <div class="col-md-4 movie-details-poster">
                    <img src="@Model.ImageURL" class="movie-img movie-details-img" width="100%" alt="@Model.Name">
                </div>
                <div class="col-md-8">
                    <div class="card-body">
                        <p class="card-text">@Model.Description</p>
                        <p class="card-text">
                            <b>Cinema: </b>
                            <a asp-controller="Cinemas" asp-action="Details" asp-route-id="@Model.CinemaId" asp-route-returnUrl="@returnUrl">
                                @Model.Cinema.Name
                            </a>
                        </p>
                        <p class="card-text">
                            <b>Producer: </b>
                            <a asp-controller="Producers" asp-action="Details" asp-route-id="@Model.ProducerId" asp-route-returnUrl="@returnUrl">
                                @Model.Producer.FullName
                            </a>
                        </p>
                        <p class="card-text"><b>Category: </b>@Model.MovieCategory</p>
                        <p class="card-text"><b>Start Date: </b>@Model.StartDate.ToString("dd MMM yy")</p>
                        <p class="card-text"><b>End Date: </b>@Model.EndDate.ToString("dd MMM yy")</p>
                        <p class="card-text ">
                            <b>Status: </b>
                            @if (DateTime.Now >= Model.StartDate && DateTime.Now <= Model.EndDate)
                            {
                                <span class="badge bg-success text-white">AVAILABLE</span>
                            }
                            else if (DateTime.Now > Model.EndDate)
                            {
                                <span class="badge bg-danger text-white">EXPIRED</span>
                            }
                            else
                            {
                                <span class="badge bg-primary text-white">UPCOMING</span>
                            }
                        </p>
                        <p class="card-text">
                            <b>Actors: </b>
                            <hr />
                            <div class="row justify-content-center  text-center">
                                @foreach (var actor in Model.Actors_Movies)
                                {
                                    <div class="col-md-4 mb-3">
                                        <img class="actor-img" src="@actor.Actor.ProfilePictureURL"  />
                                        <br />
                                        <a asp-controller="Actors" asp-action="Details" asp-route-id="@actor.ActorId" asp-route-returnUrl="@returnUrl">@actor.Actor.FullName</a>
                                    </div>
                                }
                            </div>
                        </p>

                    </div>
                </div>
                <div class="col-md-12">
                    <div class="card-footer">
                            <div class="d-flex justify-content-between align-items-center">

                                <a class="btn btn-outline-primary"
                                       asp-action="Index">
                                    Back to List
                                </a>

                                <form asp-controller="Orders"
                                      asp-action="AddItemToShoppingCart"
                                      asp-route-id="@Model.Id"
                                      method="post"
                                      class="d-inline">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-success text-white"
                                        @(DateTime.Now > Model.EndDate ? "disabled" : "")>
                                        <i class="bi bi-cart-plus"></i>
                                        Add to Cart (Price @Model.Price.ToString("c"))
                                    </button>

                                </form>

                            </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
