<div class="d-flex justify-content-center align-items-center" style="height:80vh;">
    <div class="card text-center shadow-lg p-4" style="max-width:450px; border-radius:15px;">

        <!-- Icon -->
        <div style="font-size:60px; color:#28a745;">
            ✔
        </div>

        <!-- Title -->
        <h3 class="mt-3 fw-bold">Order Completed 🎉</h3>

        <!-- Message -->
        <p class="text-muted">
            Your order has been placed successfully.<br />
            You can view your orders anytime.
        </p>

        <!-- Button -->
        <a asp-controller="Orders" asp-action="Index" class="btn btn-primary mt-3">
            View My Orders
        </a>

    </div>
</div>