@model Producer
@{
    ViewData["Title"] = "Add New Producer";
}

<link rel="stylesheet" href="~/css/actor-img.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <!-- Title -->
                <h2 id="ProducerTitle" class="text-center fw-bold mb-4">
                    Add New Producer
                </h2>

                <form asp-action="Create">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Image Preview -->
                    <div class="text-center mb-4">
                        <img id="ProfilePicturePreview"
                             src=""
                             class="rounded-circle d-none"
                             style="width:180px; height:180px; object-fit:cover; border:4px solid #0dcaf0;" />
                    </div>

                    <!-- Profile URL -->
                    <div class="mb-3">
                        <label asp-for="ProfilePictureURL" class="form-label fw-semibold"></label>
                        <input asp-for="ProfilePictureURL"
                               id="ProfilePictureURL"
                               class="form-control form-control-lg"
                               placeholder="Paste image URL (e.g. https://image.jpg)" />
                        <span asp-validation-for="ProfilePictureURL" class="text-danger"></span>
                    </div>

                    <!-- Name -->
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName"
                               id="FullNameInput"
                               class="form-control form-control-lg"
                               placeholder="e.g. Kevin Feige" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <!-- Bio -->
                    <div class="mb-4">
                        <label asp-for="Bio" class="form-label fw-semibold"></label>

                        <textarea asp-for="Bio"
                                  id="BioInput"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Write a short biography..."
                                  style="line-height:1.6;"></textarea>

                        <!-- Character Counter -->
                        <small id="bioCounter" class="text-muted">
                            0 characters
                        </small>

                        <span asp-validation-for="Bio" class="text-danger"></span>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex justify-content-between align-items-center">

                        <a class="btn btn-outline-secondary px-4"
                               asp-action="Index">
                            ← Back
                        </a>

                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-plus-circle"></i> Create
                        </button>

                    </div>

                </form>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // Image Preview
            function updateImagePreview(url) {
                var output = document.getElementById('ProfilePicturePreview');

                if (url && url.trim() !== "") {
                    output.src = url;
                    output.classList.remove("d-none");
                } else {
                    output.src = "";
                    output.classList.add("d-none");
                }
                
            }

            $("#ProfilePictureURL").on("input", function () {
                updateImagePreview($(this).val());
            });

            // Dynamic Placeholder
            function updatePlaceholder() {
                var name = $("#FullNameInput").val().trim();

                if (name.length > 0) {
                    $("#BioInput").attr(
                        "placeholder",
                        "Write a short biography about " + name + "..."
                    );
                } else {
                    $("#BioInput").attr(
                        "placeholder",
                        "Write a short biography..."
                    );
                }
            }

            $("#FullNameInput").on("input", function () {
                updatePlaceholder();

                // Title update
                var name = $(this).val();
                $("#ProducerTitle").text(name || "Add New Producer");
            });

            // Character Counter
            $("#BioInput").on("input", function () {
                var count = $(this).val().length;
                $("#bioCounter").text(count + " characters");
            });

        });
    </script>
}