@model Producer
@{
    ViewData["Title"] = "Delete Producer";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">

            <div class="card shadow-lg border-0 rounded-4 p-4 text-center">

                <!-- Icon -->
                <div class="mb-3">
                    <i class="bi bi-exclamation-triangle-fill text-danger"
                       style="font-size:40px;"></i>
                </div>

                <!-- Title -->
                <h2 class="text-danger fw-bold mb-2">
                    Delete Producer
                </h2>

                <p class="text-muted mb-4">
                    This action cannot be undone. Please confirm before deleting.
                </p>

                <!-- Image -->
                <img src="@(string.IsNullOrEmpty(Model.ProfilePictureURL) ? "/images/default-user.png" : Model.ProfilePictureURL)"
                     class="rounded-circle mx-auto mb-3 shadow"
                     style="width:140px; height:140px; object-fit:cover; border:3px solid #dc3545;" />

                <!-- Name -->
                <h4 class="fw-bold">@Model.FullName</h4>

                <!-- Bio -->
                <p class="text-muted px-3 mt-2" style="line-height:1.6;">
                    @(Model.Bio.Length > 120 ? Model.Bio.Substring(0, 120) + "..." : Model.Bio)
                </p>

                <hr />

                <!-- Buttons -->
                <div class="d-flex justify-content-center gap-3 mt-3 flex-wrap">

                    <a class="btn btn-outline-secondary px-4"
                           asp-action="Index">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>

                    <form asp-action="Delete" method="post"
                          onsubmit="return confirm('Are you sure you want to delete this producer?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </form>

                </div>

            </div>

        </div>
    </div>
</div>