@model Cinema
@{
    ViewData["Title"] = Model.Name;
}
<link rel="stylesheet" href="/css/site-ui.css" />
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <!-- Title -->
                <h2 id="CinemaTitle" class="text-center fw-bold mb-4">
                    @Model.Name
                </h2>

                <form asp-action="Edit">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- 🖼️ Image Preview (زي القديم بالظبط) -->
                    <div class="text-center mb-4">
                        <img id="CinemaLogoPreview"
                             class="border-info rounded-circle"
                             style="display:none; border:1px solid #ccc; margin:0 auto;" />
                    </div>

                    <!-- Logo -->
                    <div class="mb-3">
                        <label asp-for="Logo" class="form-label fw-semibold"></label>
                        <input asp-for="Logo" id="Logo" class="form-control form-control-lg" />
                        <span asp-validation-for="Logo" class="text-danger"></span>
                    </div>

                    <!-- Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" id="Name" class="form-control form-control-lg" placeholder="Enter cinema name..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description"
                                  id="Description"
                                  class="form-control"
                                  rows="4"
                                  maxlength="200">
                        </textarea>
                        
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <small id="descCounter" class="text-muted">0 characters</small>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex justify-content-between">

                        <a class="btn btn-outline-secondary px-4" asp-action="Index">
                            ← Back
                        </a>

                        <button type="submit" class="btn btn-outline-success px-4">
                            <i class="bi bi-check-circle"></i> Update
                        </button>


                    </div>

                </form>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
         $(document).ready(function () {

            // 🖼️ Image Preview
            function updateImagePreview(url) {
                var output = document.getElementById('CinemaLogoPreview');

                if (url && url.trim() !== "") {
                    output.src = url;
                    output.style.width = "200px";
                    output.style.height = "170px";
                    output.style.display = "block";
                } else {
                    output.src = "";
                    output.style.display = "none";
                }
            }

            updateImagePreview($("#Logo").val());

            $("#Logo").on("change", function () {
                updateImagePreview($(this).val());
            });

            function updateUI() {
                let name = $("#Name").val().trim();
                if (name === "") {
                    
                    $("#CinemaTitle").text("");
                } else {
                    $("#CinemaTitle").text(name);
                }

                // Logo Placeholder
                if (name === "") {
                    $("#Logo").attr("placeholder", "Enter image URL...");
                } else {
                    $("#Logo").attr("placeholder",
                    `/images/cinemas/${name.toLowerCase().replace(/\s/g, "-")}.jpg`);
                }

                // Description Placeholder
                if (name === "") {
                    $("#Description").attr("placeholder",
                      "Write a short description about the cinema...");
                } else {
                    $("#Description").attr("placeholder",
                      "Write a short description about " + name + "...");
                }
            }

            // ✅ تشغيل أول مرة
            updateUI();
            // ✅ عند التغيير
            $("#Name").on("input", function () {

                updateUI();
    
            });

            // 🔢 Description Counter
            function updateCounter() {
                let length = $("#Description").val().length;
                $("#descCounter").text(length + " characters");

                if (length > 150) {
                        $("#descCounter").addClass("text-danger");
                } else {

                        $("#descCounter").removeClass("text-danger");
                }
            }

            // تشغيل أول مرة
            updateCounter();

            // عند الكتابة
            $("#Description").on("input", function () {
                updateCounter();
            });

        
        });

    </script>
}