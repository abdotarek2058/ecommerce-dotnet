@model Cinema

@{
    ViewData["Title"] = Model.Name;
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
    var hasReturnUrl = !string.IsNullOrWhiteSpace(returnUrl) && Url.IsLocalUrl(returnUrl);
}
<link rel="stylesheet" href="/css/site-ui.css" />
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 p-4 text-center rounded-4">

                <!-- الصورة -->
                <input asp-for="Logo" type="hidden" id="Logo" />

                <div class="text-center mb-4">
                    <img id="CinemaLogoPreview"
                         class="border-info rounded-circle"
                         style="display:none; border:1px solid #ccc; margin:0 auto;" />
                </div>

                <!-- الاسم -->
                <h3 class="fw-bold">@Model.Name</h3>

                <hr />

                <!-- الوصف -->
                <p class="text-muted">
                    @Model.Description
                </p>

                <!-- الأزرار -->
                <div class="d-flex justify-content-center gap-3 mt-3">

                    @if (hasReturnUrl)
                    {
                        <a class="btn btn-outline-secondary px-4" href="@returnUrl">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-outline-secondary px-4" asp-action="Index">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    }

                    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <a class="btn btn-success px-4"
                               asp-action="Edit"
                               asp-route-id="@Model.Id">
                            ✏ Edit
                        </a>
                    }

                </div>

            </div>

        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {

            function updateImagePreview(url) {
                var output = document.getElementById('CinemaLogoPreview');

                if (url && url.trim() !== "") {
                    output.src = url;
                    output.style.width = "200px";
                    output.style.height = "170px";
                    output.style.display = "block";
                } else {
                    output.src = "";
                    output.style.display = "none";
                }
            }

            updateImagePreview($("#Logo").val());

        })
    </script>
}
