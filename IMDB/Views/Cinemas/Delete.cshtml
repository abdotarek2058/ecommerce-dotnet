@model Cinema
@{
    ViewData["Title"] = "Delete Cinema";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4 p-4 text-center">

                <!-- Warning Icon -->
                <div class="mb-3">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 40px;"></i>
                </div>

                <!-- Title -->
                <h2 class="text-danger fw-bold">Delete Cinema</h2>
                <p class="text-muted">This action cannot be undone. Please confirm before deleting.</p>

                <!-- Hidden Logo -->
                <input asp-for="Logo" type="hidden" id="Logo" />

                <!-- Image -->
                <div class="mb-3">
                    <img id="CinemaLogoPreview"
                         class="rounded-circle border border-danger"
                         style="display:none; border:1px solid #ccc; margin:0 auto;" />
                </div>

                <!-- Name -->
                <h5 class="fw-bold">@Model.Name</h5>

                <!-- Description -->
                <p class="text-muted">@Model.Description</p>

                <hr />

                <!-- Buttons -->
                <div class="d-flex justify-content-center gap-3">

                    <a class="btn btn-outline-secondary" asp-action="Index">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>

                    <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this actor?');">
                          
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </form>

                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            function updateImagePreview(url) {
                var output = document.getElementById('CinemaLogoPreview');

                if (url && url.trim() !== "") {
                    output.src = url;
                    output.style.width = "200px";
                    output.style.height = "170px";
                    output.style.display = "block";
                } else {
                    output.src = "";
                    output.style.display = "none";
                }
            }

            updateImagePreview($("#Logo").val());

        })
    </script>
}