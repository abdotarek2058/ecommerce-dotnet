@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="d-flex justify-content-center align-items-center" style="height:80vh;">
    
    <div class="card text-center shadow-lg p-4" style="max-width:450px; border-radius:15px;">

        <!-- Icon -->
        <div style="font-size:70px;">❌</div>

        <!-- Title -->
        <h3 class="mt-3 fw-bold text-danger">Something went wrong</h3>

        <!-- Message -->
        <p class="text-muted mt-2">
            An unexpected error occurred.<br />
            Please try again later.
        </p>

        <!-- Request ID (للديفيلوبر بس) -->
        @if (Model != null && Model.ShowRequestId)
        {
            <p class="text-muted small mt-2">
                <strong>Request ID:</strong>
                <code>@Model.RequestId</code>
            </p>
        }

        <!-- Buttons -->
        <div class="mt-3">
            <a asp-controller="Home" asp-action="Index"
                   class="btn btn-primary me-2">
                🏠 Home
            </a>

            <a asp-controller="Account" asp-action="Login"
                   class="btn btn-outline-secondary">
                🔐 Login
            </a>
        </div>

    </div>

</div>