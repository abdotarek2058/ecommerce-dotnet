@{
    ViewData["Title"] = "Email Confirmed";
}

<link rel="stylesheet" href="~/css/site-ui.css">

    <div class="d-flex justify-content-center align-items-center" style="height:80vh;">
        <div class="card text-center shadow-lg p-4" style="max-width:400px; border-radius:15px;">

            <!-- Icon -->
            <div style="font-size:60px; color:#28a745;">
                ✔
            </div>

            <!-- Title -->
            <h3 class="mt-3">Email Confirmed 🎉</h3>

            <!-- Message -->
            <p class="text-muted">
                Your account has been successfully verified.<br />
                You can now login and start using IMDB.
            </p>

            <!-- Button -->
            <a asp-controller="Account" asp-action="Login"
                   class="btn btn-primary mt-3"
                   style="border-radius:8px;">
                Go to Login
            </a>

        </div>
    </div>