@model IMDB.Core.ViewModel.ProfileVM

@{
    ViewData["Title"] = "My Profile";
}

<div class="d-flex justify-content-center mt-5">
    <div class="card shadow-lg p-4" style="max-width:500px; width:100%; border-radius:15px;">

        <h4 class="text-center mb-3">👤 My Profile</h4>

        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success text-center">
                @ViewBag.Success
            </div>
        }

        <form asp-action="Profile" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Name -->
            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <hr />

            <h6 class="text-muted">🔐 Change Password (optional)</h6>

            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label"></label>
                <input asp-for="CurrentPassword" class="form-control" placeholder="Current password" />
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" placeholder="New password" />
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <hr />

            <!-- Image Upload -->
            <div class="mb-3">
                <label class="form-label">📷 Profile Picture</label>
                <input type="file" asp-for="ProfileImage" class="form-control" />
            </div>

            <button class="btn btn-primary w-100 mt-2">
                Save Changes
            </button>

        </form>
    </div>
</div>