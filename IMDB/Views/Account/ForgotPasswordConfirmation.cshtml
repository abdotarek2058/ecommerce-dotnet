@{
    ViewData["Title"] = "Check Your Email";
}

<div class="d-flex justify-content-center align-items-center" style="height:80vh;">
    
    <div class="card text-center shadow-lg p-4" style="max-width:420px; border-radius:15px;">

        <!-- Icon -->
        <div style="font-size:60px;">📧</div>

        <!-- Title -->
        <h3 class="mt-3 fw-bold">Check Your Email</h3>

        <!-- Message -->
        <p class="text-muted mt-2">
            If an account exists with this email,<br />
            a password reset link has been sent.
        </p>

        <!-- Button -->
        <a asp-action="Login" class="btn btn-primary mt-3 px-4 py-2" style="border-radius:8px;">
            Back to Login
        </a>

    </div>

</div>