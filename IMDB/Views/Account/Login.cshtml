@model Login
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>IMDB Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">


    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>

    <div class="login-wrapper">
        <div class="login-card">
            <h2 class="title">🎬 IMDB Login</h2>
            <p class="subtitle">Login to continue</p>

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div class="input-group">
                    <input asp-for="UserName" placeholder="UserName or Email" autocomplete="username" />
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>

                <div class="input-group password-group">
                    <input asp-for="Password" type="password" placeholder="Password" />
                    <span class="toggle-password">👁</span>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="login-options">
                    <div class="remember-me">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label text-white">
                            Remember Me
                        </label>
                    </div>

                    <a asp-action="ForgotPassword" class="forgot-password">
                        Forgot your password?
                    </a>
                </div>

                <button type="submit" class="login-btn">
                    <span>Login</span>
                </button>

            </form>

                <!-- Divider -->
                <div class="divider">
                    <span>OR</span>
                </div>

                <!-- Social Login -->
                <div class="social-login"> 

                <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="provider" value="Facebook" />
                    <button type="submit" class="social-btn facebook">
                         <i class="bi bi-facebook"></i> Continue with Facebook
                    </button>
                </form>

                <form asp-action="ExternalLogin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="provider" value="Google" />
                    <button type="submit" class="social-btn google">
                         <i class="bi bi-google"></i> Continue with Google
                    </button>
                </form>

                  
                <form asp-action="ExternalLogin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="provider" value="GitHub" />
                    <button type="submit" class="social-btn github">
                        <i class="bi bi-github"></i> Continue with Github
                    </button>
                </form>
                </div>


                <p class="register-text">
                    Don't have an account?
                    <a href="/Account/Register">Register</a>
                </p>
           
        </div>
    </div>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />

</body>
</html>

