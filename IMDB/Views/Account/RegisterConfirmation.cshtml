@{
    ViewData["Title"] = "Confirm your email";
}

<div class="d-flex justify-content-center align-items-center" style="height:80vh;">
    
    <div class="card text-center shadow-lg p-4" style="max-width:420px; border-radius:15px;">

        <!-- Icon -->
        <div style="font-size:60px;">🎉</div>

        <!-- Title -->
        <h3 class="mt-3 fw-bold">Account Created Successfully</h3>

        <!-- Message -->
        <p class="text-muted mt-2">
            We've sent you a confirmation email.<br />
            Please check your inbox and activate your account.
        </p>

       

    </div>

</div>